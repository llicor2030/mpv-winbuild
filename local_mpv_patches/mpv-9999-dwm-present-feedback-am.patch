From 05c64206ac85c0cfdc4621ba10e56df7deadfbf5 Mon Sep 17 00:00:00 2001
From: t <t@t.t>
Date: Sat, 27 Jun 2026 12:04:09 +0000
Subject: [PATCH] vo/vulkan/win: DWM present feedback with stable period +
 real-phase anchor

The debug build confirmed the true DWM composition cadence is ~23.9758 Hz
(rateRefresh, qpcRefreshPeriod and the qpcVBlank/cRefresh measurement all
agree and are stable); DX11 reads 23.976024 only because exclusive-fullscreen
switches to a different physical scan-out mode. So the rate is genuinely
23.9758 on this path and must be reported as such for the A/V difference to
converge.

The previous "single-source" attempt derived the period from the per-call
qpcVBlank/cRefresh delta, but get_vsync runs once per frame so that delta
spans ~1 vblank and was extremely noisy (period swinging +/-0.5us every
frame, plus a startup 4x spike), which jittered the cadence and broke
playback.

Use DWM's already-smoothed qpcRefreshPeriod (falling back to the exact
rational rateRefresh) for the period, and re-anchor last_queue_display_time
to the real qpcVBlank every call via floor()+1 (no free-running cursor, which
accumulated phase drift; no ceil(), which could yield a past timestamp). With
a stable period and a fresh vblank each call the per-frame deltas equal one
period, so the cadence is smooth while the phase stays locked to real present
time. The qpcVBlank/cRefresh measurement is kept as a once-per-second
diagnostic only. On DWM failure we return and vo.c uses its mp_time_ns()
fallback.
---
 video/out/vulkan/context_win.c | 112 +++++++++++++++++++++++++++++++++
 1 file changed, 112 insertions(+)

diff --git a/video/out/vulkan/context_win.c b/video/out/vulkan/context_win.c
index 43bdcf2..14d0a68 100644
--- a/video/out/vulkan/context_win.c
+++ b/video/out/vulkan/context_win.c
@@ -15,9 +15,15 @@
  * License along with mpv.  If not, see <http://www.gnu.org/licenses/>.
  */
 
+#include <math.h>
+
+#include <windows.h>
+#include <dwmapi.h>
+
 #include "video/out/gpu/context.h"
 #include "video/out/gpu/d3d11_helpers.h"
 #include "video/out/w32_common.h"
+#include "osdep/timer.h"
 
 #include "common.h"
 #include "context.h"
@@ -29,6 +35,15 @@ EXTERN_C IMAGE_DOS_HEADER __ImageBase;
 struct priv {
     struct mpvk_ctx vk;
     struct mp_dxgi_factory_ctx dxgi_ctx;
+
+    // DWM present feedback, derived single-source (like the d3d11 backend):
+    // both vsync_duration and last_queue_display_time come from the SAME
+    // measured vblank cadence, so there is no basis mismatch to integrate into
+    // an A/V drift. See win_vk_get_vsync().
+    int64_t last_vblank_qpc;       // previous DwmGetCompositionTimingInfo qpcVBlank
+    int64_t last_refresh_count;    // previous cRefresh (vblank counter)
+    int64_t vsync_duration_qpc;    // measured refresh period in QPC units
+    int64_t dbg_last_log_ns;       // debug log rate-limit
 };
 
 static void win_uninit(struct ra_ctx *ctx)
@@ -63,6 +78,102 @@ static struct pl_color_space preferred_csp(struct ra_ctx *ctx)
     return (struct pl_color_space){0};
 }
 
+static int64_t qpc_to_ns(int64_t perf_freq, int64_t qpc)
+{
+    // Overflow-safe QPC(1/perf_freq s) -> ns, identical to the d3d11 backend.
+    return qpc / perf_freq * INT64_C(1000000000) +
+           qpc % perf_freq * INT64_C(1000000000) / perf_freq;
+}
+
+static void win_vk_get_vsync(struct ra_ctx *ctx, struct vo_vsync_info *info)
+{
+    struct priv *p = ctx->priv;
+
+    // This backend has no exclusive-fullscreen mode (only d3d11 does); it is
+    // always DWM-composited, so DWM owns the real present timeline. Mirror the
+    // d3d11 backend's GetFrameStatistics logic exactly, but with DWM's
+    // qpcVBlank (== SyncQPCTime) and cRefresh (== SyncRefreshCount): measure the
+    // refresh PERIOD from consecutive samples and derive BOTH vsync_duration and
+    // last_queue_display_time from that one measurement. Deriving them from a
+    // single source is what keeps vo_get_delay()/the A/V difference from
+    // accumulating drift. On failure we return and vo.c uses its raw
+    // mp_time_ns() fallback.
+    DWM_TIMING_INFO dwm = { .cbSize = sizeof(DWM_TIMING_INFO) };
+    if (FAILED(DwmGetCompositionTimingInfo(NULL, &dwm)))
+        return;
+
+    LARGE_INTEGER freq;
+    if (!QueryPerformanceFrequency(&freq) || freq.QuadPart <= 0)
+        return;
+    int64_t perf_freq = freq.QuadPart;
+
+    int64_t vblank  = (int64_t)dwm.qpcVBlank;
+    int64_t refresh = (int64_t)dwm.cRefresh;
+
+    // Refresh PERIOD: use DWM's own smoothed value (qpcRefreshPeriod, or the
+    // exact rational rateRefresh). Do NOT derive it from the per-call
+    // qpcVBlank/cRefresh delta: get_vsync runs once per frame, so that delta
+    // spans ~1 vblank and is far too noisy (it jittered the whole cadence and
+    // broke playback). qpcRefreshPeriod is already averaged by DWM and stable.
+    int64_t period_qpc = (int64_t)dwm.qpcRefreshPeriod;
+    if (period_qpc <= 0 && dwm.rateRefresh.uiNumerator && dwm.rateRefresh.uiDenominator)
+        period_qpc = perf_freq * dwm.rateRefresh.uiDenominator /
+                     dwm.rateRefresh.uiNumerator;
+    if (period_qpc <= 0)
+        return;
+
+    info->vsync_duration = qpc_to_ns(perf_freq, period_qpc);
+    info->skipped_vsyncs = -1;
+
+    // Display time of the just-flipped frame: the first vblank after "now",
+    // RE-ANCHORED to the real qpcVBlank every call (this is what keeps the
+    // phase honest so the A/V difference converges). Use floor()+1, not a
+    // free-running cursor and not ceil(): a free-running cursor accumulates a
+    // slow phase error (the A/V drift seen earlier), while ceil() could land on
+    // "now" itself (a past timestamp). With a stable period and a fresh vblank
+    // each call, the per-frame deltas equal one period -> no jitter.
+    LARGE_INTEGER qn;
+    QueryPerformanceCounter(&qn);
+    int64_t now_qpc = qn.QuadPart;
+    int64_t next;
+    if (now_qpc <= vblank) {
+        next = vblank;
+    } else {
+        int64_t k = (now_qpc - vblank) / period_qpc;
+        next = vblank + (k + 1) * period_qpc;
+    }
+
+    info->last_queue_display_time = mp_time_ns() +
+        (qpc_to_ns(perf_freq, next) - qpc_to_ns(perf_freq, now_qpc));
+
+    // Diagnostic only: a coarse per-second cadence estimate from the
+    // qpcVBlank/cRefresh delta (NOT used for timing above).
+    int64_t measured_qpc = 0;
+    if (p->last_refresh_count && refresh > p->last_refresh_count &&
+        p->last_vblank_qpc && vblank > p->last_vblank_qpc)
+        measured_qpc = (vblank - p->last_vblank_qpc) /
+                       (refresh - p->last_refresh_count);
+    p->last_refresh_count = refresh;
+    p->last_vblank_qpc = vblank;
+
+    // ---- DEBUG (about once per second) ----
+    int64_t tnow = mp_time_ns();
+    if (tnow - p->dbg_last_log_ns > INT64_C(1000000000)) {
+        p->dbg_last_log_ns = tnow;
+        double meas_hz = measured_qpc > 0 ? (double)perf_freq / (double)measured_qpc : 0.0;
+        double rr_hz = dwm.rateRefresh.uiDenominator
+            ? (double)dwm.rateRefresh.uiNumerator / (double)dwm.rateRefresh.uiDenominator
+            : 0.0;
+        double qrp_hz = dwm.qpcRefreshPeriod
+            ? (double)perf_freq / (double)dwm.qpcRefreshPeriod : 0.0;
+        MP_WARN(ctx, "DWM: measured=%.6f Hz (period_qpc=%lld) "
+                     "rateRefresh=%u/%u=%.6f qpcRefreshPeriod=%.6f Hz cRefresh=%lld\n",
+                meas_hz, (long long)period_qpc,
+                dwm.rateRefresh.uiNumerator, dwm.rateRefresh.uiDenominator, rr_hz,
+                qrp_hz, (long long)refresh);
+    }
+}
+
 static bool win_init(struct ra_ctx *ctx)
 {
     struct priv *p = ctx->priv = talloc_zero(ctx, struct priv);
@@ -87,6 +198,7 @@ static bool win_init(struct ra_ctx *ctx)
     struct ra_ctx_params params = {
         .color_depth = color_depth,
         .preferred_csp = preferred_csp,
+        .get_vsync = win_vk_get_vsync,
     };
 
     VkInstance inst = vk->vkinst->instance;
-- 
2.43.0


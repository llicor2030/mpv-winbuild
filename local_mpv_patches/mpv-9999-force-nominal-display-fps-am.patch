From 6cec92464e3499c6054e9c98cbc7bf5a8de70f8d Mon Sep 17 00:00:00 2001
From: t <t@t.t>
Date: Fri, 26 Jun 2026 06:34:59 +0000
Subject: [PATCH] vo/vulkan/win: synthesize accurate present feedback for
 display-sync

The Win32/Vulkan context provided no get_vsync, so vo.c fell back to the
mp_time_ns() timestamp taken right after flip_page(). On a 23.976 Hz
(24000/1001) display that measured cadence rounds to 24.000 Hz, which the
estimated-display-fps logic then adopts for display-sync, pulling exact
24000/1001 video to 24/1 and slowly desyncing audio.

Note this backend has no exclusive-fullscreen mode (only the d3d11 backend
does), so it is always DWM-composited and libplacebo (not mpv) owns the
Vulkan swapchain; IDXGISwapChain::GetFrameStatistics is therefore not
reachable on this path. The fix does not depend on the present path: it
synthesizes the schedule from the exact refresh rate mpv already detects on
Windows (VOCTRL_GET_DISPLAY_FPS, exact for NTSC modes). The real hardware
vsync lock still comes from VK_PRESENT_MODE_FIFO_KHR; get_vsync only feeds
vo.c the correct nominal rate.

last_queue_display_time is reported on a fixed exact-period grid: steady
playback yields exact-period deltas (no rounding drift) and gives
display-tempo/display-resample a consistent timeline, while seeks,
fast-forward, pauses and frame drops simply re-snap to the nearest grid
point so the schedule self-corrects and never runs away. skipped_vsyncs is
left at -1 so the skip detector cannot misfire during trick play.
---
 video/out/vulkan/context_win.c | 73 +++++++++++++++++++++++++++++++++-
 1 file changed, 72 insertions(+), 1 deletion(-)

diff --git a/video/out/vulkan/context_win.c b/video/out/vulkan/context_win.c
index 43bdcf2..180e8df 100644
--- a/video/out/vulkan/context_win.c
+++ b/video/out/vulkan/context_win.c
@@ -15,9 +15,12 @@
  * License along with mpv.  If not, see <http://www.gnu.org/licenses/>.
  */
 
+#include <math.h>
+
 #include "video/out/gpu/context.h"
 #include "video/out/gpu/d3d11_helpers.h"
 #include "video/out/w32_common.h"
+#include "osdep/timer.h"
 
 #include "common.h"
 #include "context.h"
@@ -29,6 +32,18 @@ EXTERN_C IMAGE_DOS_HEADER __ImageBase;
 struct priv {
     struct mpvk_ctx vk;
     struct mp_dxgi_factory_ctx dxgi_ctx;
+
+    // Synthetic presentation feedback for the Win32/Vulkan path. This backend
+    // has no exclusive-fullscreen mode (only the d3d11 backend does), so it is
+    // always composited by the DWM, and libplacebo (not mpv) owns the Vulkan
+    // swapchain, so IDXGISwapChain::GetFrameStatistics is unavailable. Rather
+    // than scrape a measured/derived cadence (which rounds 24000/1001 to a flat
+    // 24.000 Hz), build the schedule from the exact refresh rate mpv already
+    // detects on Windows (DisplayConfig rational, e.g. 24000/1001). The actual
+    // hardware vsync lock still comes from VK_PRESENT_MODE_FIFO_KHR; this only
+    // feeds vo.c the correct nominal rate. See win_vk_get_vsync().
+    int64_t vsync_period;   // exact display period in ns (0 = unknown)
+    int64_t vsync_anchor;   // fixed mp_time_ns() grid origin (0 = unset)
 };
 
 static void win_uninit(struct ra_ctx *ctx)
@@ -63,6 +78,55 @@ static struct pl_color_space preferred_csp(struct ra_ctx *ctx)
     return (struct pl_color_space){0};
 }
 
+static void win_update_vsync_period(struct ra_ctx *ctx)
+{
+    struct priv *p = ctx->priv;
+
+    // Use mpv's accurate Windows refresh-rate detection. This is exact for
+    // NTSC modes (e.g. 23.976 Hz -> period ~41708 us), unlike the measured
+    // swap cadence which rounds to 24.000 Hz and makes display-sync drift.
+    int events = 0;
+    double fps = 0;
+    if (vo_w32_control(ctx->vo, &events, VOCTRL_GET_DISPLAY_FPS, &fps) != VO_TRUE)
+        fps = 0;
+
+    int64_t period = fps > 1.0 ? llrint(1e9 / fps) : 0;
+    if (period != p->vsync_period) {
+        p->vsync_period = period;
+        p->vsync_anchor = 0;   // re-anchor the grid when the rate changes
+    }
+}
+
+static void win_vk_get_vsync(struct ra_ctx *ctx, struct vo_vsync_info *info)
+{
+    struct priv *p = ctx->priv;
+
+    int64_t period = p->vsync_period;
+    if (period <= 0)
+        return;   // leave info unset: vo.c falls back to its own timing
+
+    // Report the true physical refresh interval so display-sync uses the
+    // correct nominal rate instead of a rounded estimate.
+    info->vsync_duration = period;
+
+    // We have no per-frame skip information; never claim any, so the skip
+    // detector cannot misfire (important for seeking / fast-forward).
+    info->skipped_vsyncs = -1;
+
+    // Phase-locked grid. Snap "now" onto a fixed grid of exact-period points
+    // and report the next grid point as the predicted display time.
+    //   - During steady playback consecutive samples differ by exactly one
+    //     period, which kills the 24.000 Hz rounding drift.
+    //   - After a seek, fast-forward, pause or frame drop, "now" jumps and we
+    //     simply re-snap to the nearest grid point, so the schedule
+    //     self-corrects on the very next frame and never runs away.
+    int64_t now = mp_time_ns();
+    if (p->vsync_anchor <= 0)
+        p->vsync_anchor = now;
+    int64_t k = llrint((double)(now - p->vsync_anchor) / (double)period);
+    info->last_queue_display_time = p->vsync_anchor + (k + 1) * period;
+}
+
 static bool win_init(struct ra_ctx *ctx)
 {
     struct priv *p = ctx->priv = talloc_zero(ctx, struct priv);
@@ -87,6 +151,7 @@ static bool win_init(struct ra_ctx *ctx)
     struct ra_ctx_params params = {
         .color_depth = color_depth,
         .preferred_csp = preferred_csp,
+        .get_vsync = win_vk_get_vsync,
     };
 
     VkInstance inst = vk->vkinst->instance;
@@ -99,6 +164,8 @@ static bool win_init(struct ra_ctx *ctx)
     if (!ra_vk_ctx_init(ctx, vk, params, VK_PRESENT_MODE_FIFO_KHR))
         goto error;
 
+    win_update_vsync_period(ctx);
+
     return true;
 
 error:
@@ -114,7 +181,9 @@ static bool resize(struct ra_ctx *ctx)
 static bool win_reconfig(struct ra_ctx *ctx)
 {
     vo_w32_config(ctx->vo);
-    return resize(ctx);
+    bool ok = resize(ctx);
+    win_update_vsync_period(ctx);
+    return ok;
 }
 
 static int win_control(struct ra_ctx *ctx, int *events, int request, void *arg)
@@ -124,6 +193,8 @@ static int win_control(struct ra_ctx *ctx, int *events, int request, void *arg)
         if (!resize(ctx))
             return VO_ERROR;
     }
+    if (*events & (VO_EVENT_RESIZE | VO_EVENT_WIN_STATE))
+        win_update_vsync_period(ctx);
     return ret;
 }
 
-- 
2.43.0


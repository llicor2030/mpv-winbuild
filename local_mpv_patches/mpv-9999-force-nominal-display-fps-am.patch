From 5944ff61f989857d5498f525b8b65ce5f9f271a8 Mon Sep 17 00:00:00 2001
From: local <local@example.invalid>
Date: Fri, 26 Jun 2026 11:58:51 +0000
Subject: [PATCH] vo: keep fallback timing from becoming estimated display fps

---
 video/out/vo.c | 24 ++++++++++++++++++------
 1 file changed, 18 insertions(+), 6 deletions(-)

diff --git a/video/out/vo.c b/video/out/vo.c
index c75edbd..4a79913 100644
--- a/video/out/vo.c
+++ b/video/out/vo.c
@@ -408,12 +408,13 @@ static double vsync_stddef(struct vo *vo, double ref_vsync)
 // Check if we should switch to measured average display FPS if it seems
 // "better" then the system-reported one. (Note that small differences are
 // handled as drift instead.)
-static void check_estimated_display_fps(struct vo *vo)
+static void check_estimated_display_fps(struct vo *vo, bool has_vsync_feedback)
 {
     struct vo_internal *in = vo->in;
 
     bool use_estimated = false;
-    if (in->num_total_vsync_samples >= MAX_VSYNC_SAMPLES / 2 &&
+    if (has_vsync_feedback &&
+        in->num_total_vsync_samples >= MAX_VSYNC_SAMPLES / 2 &&
         in->estimated_vsync_interval <= 1e9 / 20.0 &&
         in->estimated_vsync_interval >= 1e9 / 400.0)
     {
@@ -474,7 +475,8 @@ static void vsync_skip_detection(struct vo *vo)
 
 // Always called locked.
 static void update_vsync_timing_after_swap(struct vo *vo,
-                                           struct vo_vsync_info *vsync)
+                                           struct vo_vsync_info *vsync,
+                                           bool has_vsync_feedback)
 {
     struct vo_internal *in = vo->in;
 
@@ -523,9 +525,18 @@ static void update_vsync_timing_after_swap(struct vo *vo,
     in->estimated_vsync_jitter =
         vsync_stddef(vo, in->vsync_interval) / in->vsync_interval;
 
-    check_estimated_display_fps(vo);
+    check_estimated_display_fps(vo, has_vsync_feedback);
     vsync_skip_detection(vo);
 
+    if (!has_vsync_feedback && in->nominal_vsync_interval > 1) {
+        // Without backend presentation feedback, the samples above come from
+        // the mp_time_ns() fallback taken after flip_page().  Keep the real
+        // display-sync mechanics intact, but do not expose that fallback
+        // average as the measured display FPS, because it can prefer rounded
+        // 24.000 Hz over a correct NTSC nominal value such as 24000/1001.
+        in->estimated_vsync_interval = in->nominal_vsync_interval;
+    }
+
     MP_STATS(vo, "value %f jitter", in->estimated_vsync_jitter);
     MP_STATS(vo, "value %f vsync-diff", MP_TIME_NS_TO_S(in->vsync_samples[0]));
 }
@@ -1022,9 +1033,10 @@ static bool render_frame(struct vo *vo)
         };
         if (vo->driver->get_vsync)
             vo->driver->get_vsync(vo, &vsync);
+        bool has_vsync_feedback = vsync.last_queue_display_time > 0;
 
         // Make up some crap if presentation feedback is missing.
-        if (vsync.last_queue_display_time <= 0)
+        if (!has_vsync_feedback)
             vsync.last_queue_display_time = mp_time_ns();
 
         stats_time_end(in->stats, "video-flip");
@@ -1033,7 +1045,7 @@ static bool render_frame(struct vo *vo)
         in->dropped_frame = prev_drop_count < vo->in->drop_count;
         in->rendering = false;
 
-        update_vsync_timing_after_swap(vo, &vsync);
+        update_vsync_timing_after_swap(vo, &vsync, has_vsync_feedback);
     }
 
     if (vo->driver->caps & VO_CAP_NORETAIN) {
-- 
